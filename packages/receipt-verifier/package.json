{
  "name": "@tessaliq/receipt-verifier",
  "version": "0.1.0-draft",
  "description": "Verify Tessaliq receipt JWTs cryptographically, offline, without calling the Tessaliq API. MIT-licensed.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tessaliq-receipt-verify": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "tessaliq",
    "receipt",
    "jwt",
    "eudi",
    "age-verification",
    "audit",
    "arcom"
  ],
  "dependencies": {
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
